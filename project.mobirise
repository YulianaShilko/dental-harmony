        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 15px)",
            "padding-bottom": "(@paddingBottom * 15px)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".row": {
              "padding": "0 1rem",
              "justify-content": "center"
            },
            ".title": {
              "max-width": "800px",
              "margin": "auto"
            },
            ".mbr-testimonial": {
              "padding": "0",
              ".card-block": {
                "-webkit-flex-grow": "0",
                "flex-grow": "0",
                ".testimonial-photo": {
                  "display": "inline-block",
                  "margin-bottom": "1.6rem",
                  "overflow": "hidden",
                  "img": {
                    "width": "100%",
                    "min-width": "100%",
                    "height": "380px",
                    "object-fit": "cover",
                    "min-height": "100%"
                  }
                }
              },
              "p": {
                "padding": "0 1rem"
              },
              ".card-footer": {
                "margin-bottom": "2.2rem",
                "border-top": "0",
                "padding": "1rem 1rem 3rem 1rem",
                "word-wrap": "break-word",
                "word-break": "break-word",
                "background": "none",
                "position": "relative",
                "&:before": {
                  "content": "''",
                  "position": "absolute",
                  "background": "@line",
                  "bottom": "-1rem",
                  "left": "50%",
                  "width": "2px",
                  "height": "3rem"
                }
              }
            },
            "@media (max-width: 300px)": {
              ".testimonial-photo": {
                "width": "100% !important",
                "height": "auto !important"
              }
            },
            ".mbr-author-desc": {
              "color": "#b69b74"
            },
            "H2": {
              "color": "#b69b74"
            },
            "@media (max-width: 992px)": {
              ".md-pb": {
                "padding-bottom": "2rem !important"
              }
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            }
          },
