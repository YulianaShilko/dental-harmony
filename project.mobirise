                "padding": "1rem 1rem 3rem 1rem",
                "word-wrap": "break-word",
                "word-break": "break-word",
                "background": "none",
                "position": "relative",
                "&:before": {
                  "content": "''",
                  "position": "absolute",
                  "background": "@line",
                  "bottom": "-1rem",
                  "left": "50%",
