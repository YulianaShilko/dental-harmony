        {
          "_name": "features8",
          "_sourceTheme": "founderm5",
          "_customHTML": "<section class=\"features8\" group=\"Features\" mbr-class=\"{'mbr-fullscreen': fullScreen,\n                    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"0\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\">\n        <input type=\"color\" title=\"Mark Color\" name=\"mark\" value=\"#7f1933\" condition=\"showTitle\" selected>\n        <header>Cards</header>\n        <select title=\"Amount\" name=\"cards\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\" selected>3</option>\n            <option value=\"4\">4</option>\n            <option value=\"5\">5</option>\n            <option value=\"6\">6</option>\n        </select>\n        <input type=\"color\" title=\"Circle Color 1\" name=\"circle_1\" value=\"#efefef\" selected>\n        <input type=\"color\" title=\"Circle Color 2\" name=\"circle_2\" value=\"#efefef\" selected>\n        <input type=\"checkbox\" title=\"Card Title\" name=\"showCardTitle\" checked>\n        <input type=\"checkbox\" title=\"Card Text\" name=\"showText\" checked>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@PROJECT_PATH@/assets/images/background1.jpg\" parallax selected>\n            <input type=\"color\" title=\"Color\" value=\"#efefef\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@PROJECT_PATH@/assets/images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#efefef\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.7\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\">\n            <div class=\"col-12\">\n                <div class=\"title-wrapper\">\n                    <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-1\" mbr-if=\"showTitle\">Наши подходы</h2>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-4 col-md-6 card\">\n                <div class=\"blur-circle\">\n                    <div class=\"circle\"></div>\n                </div>\n                <div class=\"card-wrapper\">\n                    <span mbr-icon class=\"mbr-iconfont mdi-image-filter-1\"></span>\n                    <h3 class=\"mbr-card-title mbr-fonts-style\" data-app-selector=\".mbr-card-title, .mbr-iconfont, .blur-circle\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\">Комфорт и скорость лечения</h3>\n                    <p class=\"mbr-text mbr-fonts-style\" data-app-selector=\".mbr-text\" mbr-theme-style=\"display-7\" mbr-if=\"showText\">Инновационные технологии помогают значительно сократить время лечения и сделать каждое посещение клиники более удобным и комфортным для пациента.</p>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-4 col-md-6 card\" mbr-if=\"cards > 1\">\n                <div class=\"blur-circle\">\n                    <div class=\"circle\"></div>\n                </div>\n                <div class=\"card-wrapper\">\n                    <span mbr-icon class=\"mbr-iconfont mdi-image-filter-2\"></span>\n                    <h3 class=\"mbr-card-title mbr-fonts-style\" data-app-selector=\".mbr-card-title, .mbr-iconfont, .blur-circle\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\">Безболезненное лечение</h3>\n                    <p class=\"mbr-text mbr-fonts-style\" data-app-selector=\".mbr-text\" mbr-theme-style=\"display-7\" mbr-if=\"showText\">Современное стоматологическое оборудование и передовые методы анестезии позволяют проводить лечение максимально комфортно и практически без боли.</p>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-4 col-md-6 card\" mbr-if=\"cards > 2\">\n                <div class=\"blur-circle\">\n                    <div class=\"circle\"></div>\n                </div>\n                <div class=\"card-wrapper\">\n                    <span mbr-icon class=\"mbr-iconfont mdi-image-filter-3\"></span>\n                    <h3 class=\"mbr-card-title mbr-fonts-style\" data-app-selector=\".mbr-card-title, .mbr-iconfont, .blur-circle\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\">Высокоточные технологии</h3>\n                    <p class=\"mbr-text mbr-fonts-style\" data-app-selector=\".mbr-text\" mbr-theme-style=\"display-7\" mbr-if=\"showText\">Мы применяем профессиональные инструменты и технологии высокой точности, которые обеспечивают аккуратность и надежность даже при самых сложных стоматологических процедурах.</p>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-4 col-md-6 card\" mbr-if=\"cards > 3\">\n                <div class=\"blur-circle\">\n                    <div class=\"circle\"></div>\n                </div>\n                <div class=\"card-wrapper\">\n                    <span mbr-icon class=\"mbr-iconfont mdi-image-filter-4\"></span>\n                    <h3 class=\"mbr-card-title mbr-fonts-style\" data-app-selector=\".mbr-card-title, .mbr-iconfont, .blur-circle\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\">Комфорт и скорость лечения</h3>\n                    <p class=\"mbr-text mbr-fonts-style\" data-app-selector=\".mbr-text\" mbr-theme-style=\"display-7\" mbr-if=\"showText\">Инновационные технологии помогают значительно сократить время лечения и сделать каждое посещение клиники более удобным и комфортным для пациента.</p>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-4 col-md-6 card\" mbr-if=\"cards > 4\">\n                <div class=\"blur-circle\">\n                    <div class=\"circle\"></div>\n                </div>\n                <div class=\"card-wrapper\">\n                    <span mbr-icon class=\"mbr-iconfont mobi-mbri-setting mobi-mbri\"></span>\n                    <h3 class=\"mbr-card-title mbr-fonts-style\" data-app-selector=\".mbr-card-title, .mbr-iconfont, .blur-circle\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\">IT and Technology Consulting:</h3>\n                    <p class=\"mbr-text mbr-fonts-style\" data-app-selector=\".mbr-text\" mbr-theme-style=\"display-7\" mbr-if=\"showText\">- Assisting clients in leveraging technology for business transformation and digitalization.<br>- Conducting IT assessments, technology roadmaps, and systems integration projects.<br>- Providing expertise in areas such as cloud computing, data analytics, and digital strategy.</p>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-4 col-md-6 card\" mbr-if=\"cards > 5\">\n                <div class=\"blur-circle\">\n                    <div class=\"circle\"></div>\n                </div>\n                <div class=\"card-wrapper\">\n                    <span mbr-icon class=\"mbr-iconfont mobi-mbri-users mobi-mbri\"></span>\n                    <h3 class=\"mbr-card-title mbr-fonts-style\" data-app-selector=\".mbr-card-title, .mbr-iconfont, .blur-circle\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\">Marketing and Branding Consulting:</h3>\n                    <p class=\"mbr-text mbr-fonts-style\" data-app-selector=\".mbr-text\" mbr-theme-style=\"display-7\" mbr-if=\"showText\">- Supporting clients in developing marketing strategies, brand positioning, and customer segmentation.<br>- Conducting market research, customer insights analysis, and competitive positioning.<br>- Providing guidance on digital marketing, social media strategies, and brand communication.</p>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "& when (@fullWidth)": {
              ".row": {
                "padding": "0 80px",
                "@media (max-width: 992px)": {
                  "padding": "0 35px"
                },
                "@media (max-width: 425px)": {
                  "padding": "0 24px"
                }
              }
            },
            ".row": {
              "justify-content": "center"
            },
            ".title-wrapper": {
              "position": "relative",
              "z-index": "1",
              "margin-bottom": "64px",
              "@media (max-width: 992px)": {
                "margin-bottom": "32px"
              },
              ".mbr-section-title": {
                "margin-bottom": "0",
                "span": {
                  "position": "relative",
                  "z-index": "1",
                  "&::before": {
                    "content": "''",
                    "position": "absolute",
                    "bottom": "22%",
                    "left": "0",
                    "width": "100%",
                    "height": "18px",
                    "background-color": "@mark",
                    "z-index": "-1"
                  }
                }
              }
            },
            ".card": {
              "position": "relative",
              "z-index": "1",
              "margin-bottom": "2rem",
              "transition": "all .3s ease",
              "@media (max-width: 992px)": {
                "margin-bottom": "24px"
              },
              ".blur-circle": {
                "position": "absolute",
                "top": "0",
                "left": "0",
                "width": "100%",
                ".circle": {
                  "display": "inline-block",
                  "width": "50px",
                  "height": "50px",
                  "border-radius": "100%",
                  "filter": "blur(5px) blur(5px)",
                  "background-image": "linear-gradient(90deg, @circle_1 30%, @circle_2)"
                }
              },
              ".card-wrapper": {
                "position": "relative",
                "z-index": "1",
                ".mbr-iconfont": {
                  "font-size": "50px",
                  "margin-bottom": "18px",
                  "display": "block"
                },
                ".mbr-card-title": {
                  "margin-bottom": "10px"
                },
                ".mbr-text": {
                  "margin-bottom": "0"
                }
              }
            },
            ".mbr-section-title": {
              "color": "#30758e",
              "text-align": "center"
            },
            ".mbr-text": {
              "color": "#111111",
              "text-align": "left"
            },
            ".mbr-card-title": {
              "color": "#111111"
            },
            ".mbr-card-title, .mbr-iconfont, .blur-circle": {
              "text-align": "left",
              "color": "#b69b74"
            }
          },
          "_cid": "tEpyZkZRjm",
          "_anchor": "features8-7",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 15px)",
            "padding-bottom": "(@paddingBottom * 15px)",
            ".mbr-overlay": {
              "background-color": "@overlayColor",
              "opacity": "@overlayOpacity"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "h4": {
              "max-width": "600px",
              "margin": "auto",
              "line-height": "1.4"
            },
            "@media (min-width: 767px)": {
              ".form-check-inline": {
                "margin-right": "2rem"
              },
              ".form-control-label": {
                "display": "inline-flex",
                "padding-right": "3rem",
                "margin-bottom": "0",
                "padding-left": "0.4rem"
              },
              ".check": {
                "display": "flex",
                "align-items": "flex-end"
              }
            },
            "@media (min-width: 992px)": {
              ".col, .col-lg-6": {
                "max-width": "48%"
              },
              ".form-group": {
                "margin-bottom": "0, 5rem"
              }
            },
            "@media (max-width: 992px)": {
              ".check": {
                "padding-top": "2rem",
                "padding-bottom": "2rem",
                "text-align": "center"
              },
              ".form-group": {
                "margin-bottom": "0rem"
              }
            },
            "label": {
              "margin-bottom": "0"
            },
            ".form-row": {
              "justify-content": "space-between"
            },
            "& when (@customStyle)": {
              ".form-control, .field-input": {
                "padding": "0.5rem",
                "background-color": "@fieldColor",
                "border": "none !important",
                "border-bottom": "2px solid @borderColor !important",
                "border-radius": "0",
                "color": "@formText",
                "transition": "0.4s",
                "box-shadow": "none",
                "outline": "none",
                "&:focus": {
                  "color": "@formText !important"
                },
                "&:hover": {
                  "color": "@formText !important"
                },
                "input::-webkit-input-placeholder, textarea::-webkit-input-placeholder": {
                  "color": "@formPlaceholder"
                },
                "input:-moz-placeholder, textarea:-moz-placeholder": {
                  "color": "@formPlaceholder"
                },
                "&:hover, &:focus": {
                  "background-color": "@fieldHover",
                  "border-color": "@borderHover !important",
                  "color": "contrast(@fieldHover, #000000, #ffffff, 30%)",
                  "box-shadow": "none",
                  "outline": "none",
                  "input::-webkit-input-placeholder, textarea::-webkit-input-placeholder": {
                    "color": "contrast(@formPlaceholder, #000000, #ffffff, 30%)"
                  },
                  "input:-moz-placeholder, textarea:-moz-placeholder": {
                    "color": "contrast(@formPlaceholder, #000000, #ffffff, 30%)"
                  }
                }
              },
              ".jq-number__spin:hover, .jq-number__spin:focus": {
                "background-color": "@fieldHover",
                "border-color": "@borderHover",
                "color": "contrast(@fieldHover, #000000, #ffffff, 30%)",
                "box-shadow": "none",
                "outline": "none"
              },
              ".jq-number__spin": {
                "background-color": "@fieldColor",
                "border-color": "@borderColor",
                "color": "@formText",
                "transition": "0.4s",
                "box-shadow": "none",
                "outline": "none"
              },
              ".jq-selectbox li, .jq-selectbox li": {
                "background-color": "@fieldColor",
                "color": "contrast(@fieldColor, #000000, #ffffff, 30%)"
              },
              ".jq-selectbox li:hover, .jq-selectbox li.selected": {
                "background-color": "@fieldHover",
                "color": "contrast(@fieldHover, #000000, #ffffff, 30%)"
              },
              ".jq-selectbox:hover .jq-selectbox__trigger-arrow, .jq-number__spin.minus:hover:after, .jq-number__spin.plus:hover:after": {
                "border-top-color": "@fieldColor",
                "border-bottom-color": "@fieldColor"
              },
              ".jq-selectbox .jq-selectbox__trigger-arrow, .jq-number__spin.minus:after, .jq-number__spin.plus:after": {
                "border-top-color": "@fieldHover",
                "border-bottom-color": "@fieldHover"
              }
            },
            "& when (@customStyle), (@disableElements)": {
              "input::-webkit-clear-button": {
                "display": "none"
              },
              "input::-webkit-inner-spin-button": {
                "display": "none"
              },
              "input::-webkit-outer-spin-button": {
                "display": "none"
              },
              "input::-webkit-calendar-picker-indicator": {
                "display": "none"
              }
            },
            "H5": {
              "text-align": "center",
              "color": "#343434"
            },
            "P": {
              "text-align": "center"
            },
            "LABEL": {
              "color": "#767676",
              "text-align": "center"
            },
            "H4": {
              "color": "#9c9485"
            }
          },
          "_name": "form01",
          "_sourceTheme": "woodm4",
          "_customHTML": "<section class=\"form form1 woodm4_form1\" group=\"Forms\" plugins=\"formstyler, datepicker\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"10\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"4\">\n        <header>Style</header>\n        <input type=\"checkbox\" name=\"customStyle\" title=\"Custom Style\" checked>\n        <input type=\"checkbox\" name=\"disableElements\" title=\"Disable Control\">\n        <input type=\"color\" name=\"fieldColor\" title=\"Field\" value=\"#efefef\" condition=\"customStyle\">\n        <input type=\"color\" name=\"fieldHover\" title=\"Field Hover\" value=\"#b2ccd2\" condition=\"customStyle\">\n        <input type=\"color\" name=\"borderColor\" title=\"Border\" value=\"#343434\" condition=\"customStyle\">\n        <input type=\"color\" name=\"borderHover\" title=\"Border Hover\" value=\"#343434\" condition=\"customStyle\">\n        <input type=\"color\" name=\"formText\" title=\"Text\" value=\"#343434\" condition=\"customStyle\">\n        <input type=\"color\" name=\"formPlaceholder\" title=\"Placeholders\" value=\"#343434\" condition=\"customStyle\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\">\n            <input type=\"image\" title=\"Background Image\" value=\"@PROJECT_PATH@/assets/images/work-dentist3-1919x1535.jpg\" selected>\n            <input type=\"color\" title=\"Background Color\" value=\"#f1eeea\">\n        </fieldset>\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#efefef\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.4\" condition=\"overlay && bg.type !== 'color'\">\n    <input type=\"hidden\" name=\"usedRecaptcha\" value=\"false\"></mbr-parameters>\n\n    <div class=\"mbr-overlay\" mbr-if=\"(overlay && bg.type=='image')\"></div>\n\n    <div class=\"container\">\n        <div class=\"row\">\n            <div mbr-form class=\"col-lg-10 col-md-12 mx-auto mbr-form\">\n<!--Formbuilder Form-->\n<form action=\"support@dental-harmony.com\" name=\"Form Name\" method=\"POST\" class=\"mbr-form form-with-styler\" data-verified=\"support@enconsabiedriba.com\">\n<div class=\"form-row\">\n<div hidden=\"hidden\" data-form-alert class=\"alert alert-success col-12\">Мы свяжемся с Вами в ближайшее время!</div>\n<div hidden=\"hidden\" data-form-alert-danger class=\"alert alert-danger col-12\">Oops...! some problem!</div>\n</div>\n<div class=\"dragArea form-row\">\n<div class=\"col-lg-12 col-md-12 col-sm-12\">\n<h5 mbr-theme-style=\"display-1\" class=\"mbr-fonts-style pb-2\"></h5>\n</div>\n<div class=\"col-lg-12 col-md-12 col-sm-12\">\n<p mbr-theme-style=\"display-5\" class=\"mbr-fonts-style pb-5\">\n</p>\n</div>\n<div class=\"col-lg-12 col-md-12 col-sm-12 form-group\">\n<div class=\"form-row row\">\n<div class=\"col\">\n<input type=\"text\" name=\"nameFirst\" placeholder=\"Имя\" data-form-field=\"nameFirst\" required=\"required\" class=\"form-control text-multiple\" value>\n</div>\n<div class=\"col\">\n<input type=\"text\" name=\"nameLast\" placeholder=\"Last Name\" data-form-field=\"nameLast\" required=\"required\" class=\"form-control text-multiple\" value hidden=\"hidden\">\n</div>\n</div>\n</div>\n<div data-for=\"phone\" class=\"col-lg-6 col-md-12 col-sm-12 form-group\">\n<input type=\"tel\" name=\"phone\" placeholder=\"Телефон\" data-form-field=\"phone\" mbr-theme-style=\"display-7\" class=\"form-control\" pattern=\"*\" value>\n</div>\n<div data-for=\"email\" class=\"col-lg-6 col-md-12 col-sm-12 form-group\">\n<input type=\"email\" name=\"email\" placeholder=\"Email\" data-form-field=\"email\" mbr-theme-style=\"display-7\" class=\"form-control\" required=\"required\" value>\n</div>\n<div data-for=\"message\" class=\"col-lg-6 col-md-12 col-sm-12 form-group\">\n<textarea name=\"message\" placeholder=\"Сообщение\" data-form-field=\"message\" mbr-theme-style=\"display-7\" class=\"form-control\" required=\"required\"></textarea>\n</div>\n<div mbr-buttons=\"true\" mbr-theme-style=\"display-7\" data-toolbar=\"-mbrBtnMove,-mbrLink,-mbrBtnRemove,-mbrBtnAdd\" class=\"col-auto m-auto pt-5\"><a type=\"submit\" class=\"w-100 w-100 w-100 btn btn-secondary\" data-app-placeholder=\"Введите Текст\">Отправить</a></div>\n<div class=\"col-lg-12 col-md-12 col-sm-12\">\n<h4 mbr-theme-style=\"display-4\" class=\"mbr-fonts-style align-center pt-4\">\n</h4>\n</div>\n</div>\n</form><!--Formbuilder Form-->\n</div>\n        </div>\n    </div>\n</section>",
          "_cid": "tEpvoTAsMC",
          "_anchor": "form01-6",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_name": "contact4",
          "_sourceTheme": "bistrom5",
          "_customHTML": "<section data-bs-version=\"5\" class=\"contact4\" group=\"Contact\" mbr-class=\"{'mbr-parallax-background':bg.parallax}\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverse\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\">\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\" checked>\n        <input type=\"checkbox\" title=\"Column 2\" name=\"showColumn\">\n        <input type=\"color\" title=\"Icons Color\" value=\"#202020\" name=\"iconsColor\">\n        <header>Map</header>\n        <input type=\"map\" title=\"Map\" name=\"googleMap\" place-id=\"Могилёв, ул. Бонч-Бруевича 5\" value=\"Могилёв, ул. Бонч-Бруевича 5\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/bistrom5/components/_images/background.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#efefef\" selected>\n        </fieldset>\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid' : fullWidth}\">\n        <div class=\"row justify-content-center align-items-center\" mbr-class=\"{'flex-row-reverse' : reverse}\">\n            <div class=\"map-wrapper col-12 col-lg-6\">\n                <div class=\"google-map\" mbr-map=\"googleMap\">\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-6\">\n                <div class=\"header_box\">\n                    <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-1\" mbr-if=\"showTitle\" data-app-selector=\".card-title\">Контакты</h4>\n                    <p class=\"mbr-text mb-0 mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text\">Lorem ipsum dolor sit amet, consectetur adipisicing elit. Nobis similique eos nesciunt tenetur animi excepturi doloribus, possimus!</p>\n                </div>\n                <div class=\"row\">\n                    <div class=\"col-12\" mbr-class=\"{'col-sm-6 col-lg-6' : showColumn}\">\n                        <div class=\"column_wrap\">\n                            <h4 class=\"mbr-section-subtitle mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\"></h4>\n                            <div class=\"contact_content\">\n                                <div class=\"iconfont-wrapper\">\n                                    <span mbr-icon class=\"mbr-iconfont mobi-mbri-home mobi-mbri\" style=\"color: rgb(121, 185, 208); fill: rgb(121, 185, 208);\"></span>\n                                </div>\n                                <p class=\"card_text mb-0 mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".card_text, .contact_content\">г. Могилев, ул. Бонч-Бруевича 5<br></p>\n                            </div>\n                            <div class=\"contact_content\">\n                                <div class=\"iconfont-wrapper\">\n                                    <span mbr-icon class=\"mbr-iconfont mobi-mbri-up-down mobi-mbri\" style=\"font-size: 1px;\"></span>\n                                </div>\n                                <p class=\"card_text mb-0 mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".card_text, .contact_content\"></p>\n                            </div>\n                            <div class=\"contact_content\">\n                                <div class=\"iconfont-wrapper\">\n                                    <span mbr-icon class=\"mbr-iconfont mobi-mbri-letter mobi-mbri\" style=\"color: rgb(121, 185, 208); fill: rgb(121, 185, 208);\"></span>\n                                </div>\n                                <p class=\"card_text mb-0 mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".card_text, .contact_content\"><a href=\"index.html\" class=\"text-primary\">support@nicoladellederaa.com</a></p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"col-12 col-sm-6 col-lg-6\" mbr-if=\"showColumn\">\n                        <div class=\"column_wrap\">\n                            <h4 class=\"mbr-section-subtitle mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\">Location 2</h4>\n                            <div class=\"contact_content\">\n                                <div class=\"iconfont-wrapper\">\n                                    <span mbr-icon class=\"mbr-iconfont mobi-mbri-home mobi-mbri\"></span>\n                                </div>\n                                <p class=\"card_text mb-0 mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".card_text, .contact_content\">350 5th Ave, New York, NY 10118</p>\n                            </div>\n                            <div class=\"contact_content\">\n                                <div class=\"iconfont-wrapper\">\n                                    <span mbr-icon class=\"mbr-iconfont mobi-mbri-phone mobi-mbri\"></span>\n                                </div>\n                                <p class=\"card_text mb-0 mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".card_text, .contact_content\">+9 876-543-2100</p>\n                            </div>\n                            <div class=\"contact_content\">\n                                <div class=\"iconfont-wrapper\">\n                                    <span mbr-icon class=\"mbr-iconfont mobi-mbri-letter mobi-mbri\"></span>\n                                </div>\n                                <p class=\"card_text mb-0 mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".card_text, .contact_content\">mobirise@company.com</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".card-title": {
              "margin-bottom": "20px",
              "color": "#b69b74"
            },
            ".mbr-section-subtitle": {
              "margin-bottom": "20px",
              "color": "#202020"
            },
            "@media (min-width: 992px)": {
              ".google-map when not (@reverse)": {
                "margin-right": "17%"
              },
              ".google-map when (@reverse)": {
                "margin-left": "17%"
              }
            },
            ".google-map": {
              "height": "540px",
              "position": "relative",
              "@media (max-width: 991px)": {
                "margin-bottom": "70px"
              },
              "iframe": {
                "height": "100%",
                "width": "100%"
              },
              "[data-state-details]": {
                "color": "#6b6763",
                "height": "1.5em",
                "margin-top": "-0.75em",
                "padding-left": "1.25rem",
                "padding-right": "1.25rem",
                "position": "absolute",
                "text-align": "center",
                "top": "50%",
                "width": "100%"
              },
              "&[data-state]": {
                "background": "#e9e5dc"
              },
              "&[data-state=\"loading\"]": {
                "[data-state-details]": {
                  "display": "none"
                }
              }
            },
            ".header_box": {
              "margin-bottom": "40px"
            },
            ".contact_content": {
              "display": "inline-block",
              "width": "100%",
              "margin-bottom": "8px"
            },
            ".card_text": {
              "display": "inline-block"
            },
            ".iconfont-wrapper": {
              "margin-right": "15px",
              "display": "inline-block",
              "width": "19px",
              "height": "19px",
              "font-size": "19px",
              "color": "@iconsColor"
            },
            "@media (max-width: 767px)": {
              ".column_wrap": {
                "margin-bottom": "29px"
              }
            },
            ".card_text, .contact_content": {
              "color": "#343434"
            }
          },
