        {
          "_customTemplate": true,
          "_afterNavbarItem": false,
          "_customHTML": "<hr>",
          "_customCSS": "/* Type valid CSS here */\n\nhr {\n    background: #87999F;\n    padding: 10px 0 0 0 ;\n    border: none;\n}",
          "alias": "code-editor",
